    "@types/bcryptjs": "^2.4.5",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.10",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "tsx": "^4.1.4",
    "typescript": "^5.2.2"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@jmlq/logger": "alpha"
  },
