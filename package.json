{
  "name": "@jmlq/logger-plugin-postgresql",
  "description": "postgresql plugin for JMLQ Logger implementing Clean Architecture principles.",
  "version": "0.1.0-alpha.15",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/MLahuasi/jmlq-logger-plugin-postgresql.git"
  },
  "homepage": "https://github.com/MLahuasi/jmlq-logger-plugin-postgresql#readme",
  "scripts": {
    "dev": "rimraf dist && mkdir dist && tsc -p tsconfig.json",
    "build": "rimraf dist && mkdir dist && tsc -p tsconfig.build.json",
